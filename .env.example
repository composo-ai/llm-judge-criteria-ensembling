# Copy this file to .env and fill in your values.
# cp .env.example .env

# GPT-5.4 (full model) — used by all conditions
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

# GPT-5.4 mini — only needed for escalation and combined conditions
AZURE_OPENAI_MINI_API_KEY=your-azure-openai-mini-api-key
AZURE_OPENAI_MINI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_MINI_DEPLOYMENT=gpt-5.4-mini
